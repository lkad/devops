{
  "name": "devops-toolkit",
  "version": "1.0.0",
  "description": "DevOps system with device management, CI/CD, and monitoring",
  "main": "cmd/main.js",
  "scripts": {
    "start": "node cmd/main.js",
    "start:server": "node server.js",
    "test": "jest --config=test/jest.config.js",
    "test:test-lab": "bash devices/scripts/run-tests.sh",
    "dev": "nodemon cmd/main.js",
    "dev:server": "nodemon server.js",
    "docker:up": "docker-compose -f devices/docker/docker-compose.test.yml up -d",
    "docker:down": "docker-compose -f devices/docker/docker-compose.test.yml down",
    "test:full": "{ docker-compose -f devices/docker/docker-compose.test.yml up -d && test; docker-compose -f devices/docker/docker-compose.test.yml down }"
  },
  "keywords": [
    "devops",
    "device-management",
    "ci-cd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.1",
    "uuid": "^9.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
